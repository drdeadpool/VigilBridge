# Required
DATABASE_URL=postgresql+asyncpg://vigil:vigil@localhost:5432/vigil
INGEST_API_KEY=replace-with-random-ingest-key
READ_API_KEY=replace-with-separate-random-read-key

# Optional
LOG_LEVEL=INFO
ENABLE_DOCS=false

# Docker Compose only (not used by app directly)
POSTGRES_USER=vigil
POSTGRES_PASSWORD=vigil
POSTGRES_DB=vigil

# Render injects PORT automatically (default 10000) — do not set manually on Render
# The app accepts postgresql://, postgres://, or postgresql+asyncpg:// — all normalised at startup
